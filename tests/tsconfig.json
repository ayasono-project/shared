{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "isolatedDeclarations": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "rootDir": "..",
    "types": ["node", "vitest/globals"]
  },
  "include": ["./**/*.ts", "../src/**/*.ts"]
}
